# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=3000
NODE_ENV=development

# ==========================================
# DATABASE - SUPABASE (PostgreSQL)
# ==========================================
# Obtener credenciales en:
# https://supabase.com/dashboard/project/pemudfoinavlslhkgjlk/settings/database

DB_HOST=db.pemudfoinavlslhkgjlk.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_supabase_password_here
DB_SSL=true

# ==========================================
# VARIABLES DE ENTORNO - INTEGRACIONES
# ==========================================

# === GOOGLE CALENDAR ===
# Obtener en: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/auth/google/callback

# === ICLOUD CALENDAR ===
# Usar contraseña de aplicación Apple (no la principal)
# Generar en: https://appleid.apple.com/account/manage
ICLOUD_EMAIL=your_email@icloud.com
ICLOUD_APP_PASSWORD=your_app_specific_password

# === NOTION ===
# Obtener token en: https://www.notion.so/my-integrations
# Crear database y obtener ID en: https://notion.so/my-databases
NOTION_API_KEY=secret_your_notion_token
NOTION_DATABASE_ID=your_database_id_here

# === SINCRONIZACIÓN ===
SYNC_INTERVAL_MINUTES=60
AUTO_SYNC_ENABLED=true
SYNC_ON_CREATE=true
SYNC_ON_UPDATE=true

# === SESSION & SECURITY ===
SESSION_SECRET=generate_strong_random_string_here
ENCRYPTION_KEY=generate_strong_random_encryption_key_here
NODE_ENV=development
PORT=3000
